{
  "name": "asciidoc-local-preview",
  "displayName": "AsciiDoc Local Preview",
  "description": "Local AsciiDoc preview for VS Code with MathJax, Mermaid, PlantUML, and Kroki-compatible diagrams.",
  "version": "0.0.4",
  "publisher": "YoshihideShirai",
  "license": "MIT",
  "icon": "media/extension-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/YoshihideShirai/asciidoc-local-preview-vscode.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "activationEvents": [
    "onCommand:asciidoc-local-preview.openPreview",
    "onCommand:asciidoc-local-preview.refreshPreview",
    "onCommand:asciidoc-local-preview.toggleBold",
    "onCommand:asciidoc-local-preview.toggleItalic",
    "onCommand:asciidoc-local-preview.toggleMonospace",
    "onCommand:asciidoc-local-preview.insertLink",
    "onCommand:asciidoc-local-preview.insertHeading",
    "onCommand:asciidoc-local-preview.insertUnorderedList"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "asciidoc-local-preview.openPreview",
        "title": "Open Local AsciiDoc Preview",
        "category": "AsciiDoc",
        "icon": "$(open-preview)"
      },
      {
        "command": "asciidoc-local-preview.refreshPreview",
        "title": "Refresh Preview",
        "category": "AsciiDoc"
      },
      {
        "command": "asciidoc-local-preview.toggleBold",
        "title": "Bold",
        "category": "AsciiDoc"
      },
      {
        "command": "asciidoc-local-preview.toggleItalic",
        "title": "Italic",
        "category": "AsciiDoc"
      },
      {
        "command": "asciidoc-local-preview.toggleMonospace",
        "title": "Monospace",
        "category": "AsciiDoc"
      },
      {
        "command": "asciidoc-local-preview.insertLink",
        "title": "Insert Link",
        "category": "AsciiDoc"
      },
      {
        "command": "asciidoc-local-preview.insertHeading",
        "title": "Insert Section Heading",
        "category": "AsciiDoc"
      },
      {
        "command": "asciidoc-local-preview.insertUnorderedList",
        "title": "Insert Unordered List",
        "category": "AsciiDoc"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "asciidoc-local-preview.openPreview",
          "when": "resourceLangId == asciidoc || resourceExtname == .adoc || resourceExtname == .ad || resourceExtname == .asciidoc || resourceExtname == .asc",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "asciidoc-local-preview.openPreview",
          "when": "resourceLangId == asciidoc || resourceExtname == .adoc || resourceExtname == .ad || resourceExtname == .asciidoc || resourceExtname == .asc",
          "group": "navigation"
        },
        {
          "command": "asciidoc-local-preview.toggleBold",
          "when": "editorLangId == asciidoc || resourceExtname == .adoc || resourceExtname == .ad || resourceExtname == .asciidoc || resourceExtname == .asc",
          "group": "1_modification"
        },
        {
          "command": "asciidoc-local-preview.toggleItalic",
          "when": "editorLangId == asciidoc || resourceExtname == .adoc || resourceExtname == .ad || resourceExtname == .asciidoc || resourceExtname == .asc",
          "group": "1_modification"
        },
        {
          "command": "asciidoc-local-preview.toggleMonospace",
          "when": "editorLangId == asciidoc || resourceExtname == .adoc || resourceExtname == .ad || resourceExtname == .asciidoc || resourceExtname == .asc",
          "group": "1_modification"
        },
        {
          "command": "asciidoc-local-preview.insertLink",
          "when": "editorLangId == asciidoc || resourceExtname == .adoc || resourceExtname == .ad || resourceExtname == .asciidoc || resourceExtname == .asc",
          "group": "1_modification"
        },
        {
          "command": "asciidoc-local-preview.insertHeading",
          "when": "editorLangId == asciidoc || resourceExtname == .adoc || resourceExtname == .ad || resourceExtname == .asciidoc || resourceExtname == .asc",
          "group": "1_modification"
        },
        {
          "command": "asciidoc-local-preview.insertUnorderedList",
          "when": "editorLangId == asciidoc || resourceExtname == .adoc || resourceExtname == .ad || resourceExtname == .asciidoc || resourceExtname == .asc",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run clean && npm run compile && npm run bundle",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --external:@asciidoctor/core --outfile=out/extension.js --sourcemap",
    "clean": "rm -rf out",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "verify:no-network": "node scripts/verify-no-network.js",
    "pretest": "npm run compile && npm run bundle && npm run lint && npm run verify:no-network",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@plantuml/core": "^1.2026.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "asciidoctor-emoji": "^0.5.0",
    "bit-field": "^1.9.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.3",
    "json5": "^2.2.3",
    "mathjax": "^4.1.2",
    "mermaid": "^11.15.0",
    "nomnoml": "^1.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vega": "^6.2.0",
    "vega-interpreter": "^2.2.1",
    "vega-lite": "^6.4.3",
    "wavedrom": "^3.6.1"
  },
  "dependencies": {
    "@asciidoctor/core": "^2.2.7"
  }
}
